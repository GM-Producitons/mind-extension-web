    {
      "id": "pTClbzEuE_HBCP1Pl_-tZ",
      "type": "text",
      "x": 2850.003883271973,
      "y": 29.29682404167771,
      "width": 672.6395263671875,
      "height": 225,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
